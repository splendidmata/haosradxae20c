# HAOS boot script for Radxa E20C (RK3528)
# Does NOT use fileenv (not available in Radxa U-Boot)
# Compiled to boot.scr by Buildroot

setenv bootargs earlycon=uart8250,mmio32,0xff130000 console=ttyS0,1500000n8

echo "Loading HAOS kernel..."
load mmc 1:1 ${kernel_addr_r} Image

echo "Loading RK3528-E20C device tree..."
load mmc 1:1 ${fdt_addr_r} rk3528-radxa-e20c.dtb

fdt addr ${fdt_addr_r}

echo "Booting..."
booti ${kernel_addr_r} - ${fdt_addr_r}
